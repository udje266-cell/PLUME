<?xml version="1.0" encoding="utf-8"?>
<!--
  Désactive toute sauvegarde/restauration des données de l'app (cloud + transfert
  d'appareil). Empêche notamment la restauration du token d'authentification à la
  réinstallation (sinon un compte se reconnecte « automatiquement »).
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>

# ── Serveur ──────────────────────────────────────────────────────────────────
PORT=3000

# Secret JWT (OBLIGATOIRE en production, ≥ 16 caractères — ne jamais laisser la
# valeur par défaut).
JWT_SECRET="changez-moi-en-production"

# ── Base de données (PostgreSQL — aligné avec prisma/schema.prisma) ──────────
# Runtime. En production multi-instances, pointer vers un POOLER, ex. :
#   postgresql://user:pwd@host/db?pgbouncer=true&connection_limit=5&pool_timeout=20
DATABASE_URL="postgresql://utilisateur:mot_de_passe@localhost:5432/nom_de_base?schema=public"

# Connexion DIRECTE pour les migrations (un pooler transaction-mode ne migre
# pas). En mono-instance / sans pooler : laisser vide, le start script utilise
# automatiquement DATABASE_URL.
DIRECT_URL=""

# ── E-mail OTP (Brevo API) ───────────────────────────────────────────────────
# Clé d'API Brevo v3. SANS elle, aucun e-mail OTP n'est envoyé → l'inscription
# (qui exige un code par e-mail) ne peut pas aboutir.
BREVO_API_KEY="votre-cle-api-brevo"
SMTP_FROM="PLUME <udje266@gmail.com>"

# ── Upload d'images (Cloudinary) ─────────────────────────────────────────────
VITE_CLOUDINARY_CLOUD_NAME="votre-cloud-name"
VITE_CLOUDINARY_UPLOAD_PRESET="votre-upload-preset"

# ── URL publique / CORS ──────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
# Origines autorisées (séparées par des virgules). Les origines Capacitor
# (capacitor://localhost, https://localhost…) sont déjà tolérées d'office.
CORS_ORIGINS=""

# ── Build de l'app MOBILE (Capacitor) ────────────────────────────────────────
# URL ABSOLUE du backend déployé, injectée au build natif (sinon les appels /api
# échouent dans l'app). Inutile pour le web servi en same-origin.
VITE_API_URL="https://plume-app-fudd.onrender.com"

# ── Assistant d'écriture IA (Google Gemini — optionnel) ──────────────────────
# Clé API Google AI Studio (https://aistudio.google.com/apikey — palier gratuit).
# SANS elle, les outils d'écriture basculent sur le moteur LOCAL hors-ligne.
GEMINI_API_KEY=""
# Modèle Gemini à utiliser (défaut : gemini-1.5-flash — palier gratuit robuste).
GEMINI_MODEL="gemini-1.5-flash"

# ── Montée en charge (optionnel — cf. SCALING.md) ────────────────────────────
# Active la cohérence multi-instances (rate-limit, anti-spam, Socket.io).
# Laisser vide en mono-instance / développement.
REDIS_URL=""

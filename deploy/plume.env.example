# Variables d'environnement de PLUME sur la VM (copie vers /etc/plume.env).
#   sudo cp deploy/plume.env.example /etc/plume.env
#   sudo nano /etc/plume.env        # renseigne les valeurs
#   sudo chmod 600 /etc/plume.env    # protège les secrets

NODE_ENV=production
PORT=3000

# Base PostgreSQL locale (créée sur la VM). Mets un VRAI mot de passe.
DATABASE_URL=postgresql://plume:MOT_DE_PASSE@localhost:5432/plume
# Connexion directe pour les migrations (= identique sans pooler).
DIRECT_URL=postgresql://plume:MOT_DE_PASSE@localhost:5432/plume

# Secret JWT (≥16 caractères, généré aléatoirement) :
#   openssl rand -base64 24
JWT_SECRET=CHANGE_MOI_secret_aleatoire_long

# E-mails OTP (Brevo) — obligatoire pour l'inscription.
BREVO_API_KEY=xkeysib-xxxxxxxx
SMTP_FROM=PLUME <udje266@gmail.com>

# Uploads d'images (Cloudinary).
VITE_CLOUDINARY_CLOUD_NAME=ton-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=ton-upload-preset

# Compte administrateur créé/garanti au démarrage (facultatif).
ADMIN_EMAIL=udje266@gmail.com
ADMIN_PASSWORD=CHANGE_MOI

# URL publique (ton domaine HTTPS).
APP_URL=https://ton-sous-domaine.duckdns.org

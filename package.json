{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs && esbuild prisma/seed.ts --bundle --platform=node --format=cjs --packages=external --outfile=dist/seed.cjs",
    "start": "DIRECT_URL=\"${DIRECT_URL:-$DATABASE_URL}\" prisma migrate deploy && (node dist/seed.cjs || echo '[seed] ignoré') && node dist/server.cjs",
    "clean": "rm -rf dist server.js server.cjs",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "build:mobile": "vite build",
    "cap:sync": "npm run build:mobile && cap sync",
    "cap:assets": "capacitor-assets generate",
    "cap:android": "npm run build:mobile && cap sync android && cap open android",
    "cap:ios": "npm run build:mobile && cap sync ios && cap open ios",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:cleanup-demo": "tsx prisma/cleanup-demo.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@prisma/client": "^6.8.2",
    "@socket.io/redis-adapter": "^8.3.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase-admin": "^14.0.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "nodemailer": "^8.0.10",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-easy-crop": "^5.5.7",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "prisma": "^6.8.2",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.8"
  }
}

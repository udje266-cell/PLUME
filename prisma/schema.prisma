generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Runtime : connexion POOLÉE (ex. PgBouncer / pooler managé) pour ne pas
  // épuiser les connexions Postgres avec plusieurs instances. Ajouter
  // `?pgbouncer=true&connection_limit=5` à l'URL en mode pooler.
  url      = env("DATABASE_URL")
  // Migrations / introspection : connexion DIRECTE (un pooler en mode
  // « transaction » ne supporte pas les migrations). En l'absence de pooler,
  // le start script fait DIRECT_URL = DATABASE_URL automatiquement.
  directUrl = env("DIRECT_URL")
}


model User {
  id                String   @id @default(cuid())
  username          String   @unique
  email             String   @unique
  passwordHash      String?
  role              String   @default("Lecteur")
  avatar            String?
  // Bannière de profil persistée côté serveur (visible par toute la communauté).
  banner            String?
  // Stickers personnalisés (JSON array d'URLs) — persistés pour survivre à une
  // réinstallation de l'app.
  customStickers    String?
  bio               String   @default("")
  isVerified        Boolean  @default(false)
  emailVerified     Boolean  @default(false)
  birthDate         DateTime?
  gender            String?
  hasChangedRole    Boolean  @default(false)
  // Dates des dernières modifications soumises à délai (pseudo: 30j, e-mail: 90j).
  usernameChangedAt DateTime?
  emailChangedAt    DateTime?
  // Version de session : incrémentée au reset/changement de mot de passe et au
  // bannissement pour INVALIDER immédiatement tous les JWT déjà émis.
  tokenVersion      Int      @default(0)
  isFlagged         Boolean  @default(false)
  flagReason        String?
  // Compte suspendu par un administrateur : bloque la connexion (réversible).
  isBanned          Boolean  @default(false)
  // Compte mis en avant par un administrateur (visibilité accrue).
  featured          Boolean  @default(false)
  // Système de niveaux (XP) : deux jauges séparées (lecteur / auteur).
  readerXp          Int      @default(0)
  authorXp          Int      @default(0)
  // Compteurs anti-abus journaliers (date + nombres d'actions plafonnées).
  xpMeta            Json?
  favoriteGenres String  @default("[]")

  showFollowers     Boolean  @default(true)
  showFollowing     Boolean  @default(true)
  showFriends       Boolean  @default(true)
  showMentions      Boolean  @default(true)
  privateProfile    Boolean  @default(false)
  showBooksRead     Boolean  @default(false)
  showBooksWritten  Boolean  @default(false)
  showPalmares      Boolean  @default(true)
  allowMessages     Boolean  @default(true)
  whoCanFollow      String   @default("everyone")
  whoCanComment     String   @default("everyone")
  readingTheme      String?
  readingFontSize   String?
  readingFontFamily String?
  readingFullscreen Boolean  @default(false)
  autoSaveEnabled   Boolean  @default(true)
  confirmDeleteStory Boolean @default(true)
  // Vitrine de trophees mis en avant (snapshots {id,title}) visible par tous.
  showcase          Json?
  // Statistiques de progression des SUCCES (UserStats) : persistees serveur pour
  // survivre au changement d'appareil / vidage de cache, et etre visibles par
  // les autres (au lieu d'etre coincees en localStorage).
  stats             Json?

  stories           Story[]
  comments          Comment[]
  commentReplies    CommentReply[]
  conversations     Conversation[] @relation("UserConversations")
  messages          Message[]
  readingGroups     ReadingGroup[] @relation("GroupMembers")
  createdGroups     ReadingGroup[] @relation("GroupCreator")
  groupMemberships  GroupMember[]
  groupReactions    GroupMessageReaction[]
  groupReads        GroupRead[]
  groupMessages     GroupMessage[]
  following         Follow[]  @relation("UserFollowing")
  followers         Follow[]  @relation("UserFollowers")
  friendshipsSent   Friendship[] @relation("FriendshipRequester")
  friendshipsReceived Friendship[] @relation("FriendshipReceiver")
  notifications     Notification[]
  readingProgress   ReadingProgress[]
  readingHistory    ReadingHistory[]
  readingListEntries ReadingListEntry[]
  chapterReads      ChapterRead[]
  savedQuotes       SavedQuote[]
  likes             StoryLike[]
  commentLikes      CommentLike[]
  storyRatings      StoryRating[]
  favorites         Favorite[]
  blockedUsers      BlockedUser[] @relation("Blocker")
  blockedBy         BlockedUser[] @relation("Blocked")
  reportsMade       Report[] @relation("ReportReporter")
  reportsReceived   Report[] @relation("ReportReported")

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Story {
  id             String      @id @default(cuid())
  title          String
  description    String
  cover          String?
  genre          String
  category       String?
  ambiance       String?
  format         String?
  language       String      @default("fr")
  tags String @default("[]")
  status         String      @default("BROUILLON")
  views          Int         @default(0)
  reads          Int         @default(0)
  rating         Float       @default(0)
  isFlagged      Boolean     @default(false)
  flagReason     String?
  featured       Boolean     @default(false)
  ageRating      String      @default("ALL")

  authorId       String
  author         User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  chapters       Chapter[]
  comments       Comment[]
  likes          StoryLike[]
  ratings        StoryRating[]
  favorites      Favorite[]
  readingProgress ReadingProgress[]
  readingHistory ReadingHistory[]

  publishedAt    DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([authorId])
  @@index([status])
  @@index([genre])
  @@index([createdAt])
}

model Chapter {
  id          String   @id @default(cuid())
  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  title       String
  content     String
  order       Int
  isPublished Boolean  @default(false)
  views       Int      @default(0)
  reads       Int      @default(0)
  publishedAt DateTime?
  comments    Comment[]
  readingProgress ReadingProgress[]
  readingHistory ReadingHistory[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([storyId, order])
  @@index([storyId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  receiverId  String
  status      String           @default("PENDING")
  requester   User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver    User @relation("FriendshipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([requesterId, receiverId])
  @@index([requesterId])
  @@index([receiverId])
}

model Conversation {
  id           String    @id @default(cuid())
  participants User[]    @relation("UserConversations")
  messages     Message[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Message {
  id             String       @id @default(cuid())
  senderId       String
  conversationId String
  content        String
  isDelivered    Boolean      @default(false)
  isRead         Boolean      @default(false)
  // Réponse à un autre message (WhatsApp-like) + édition + suppression globale.
  replyToId      String?
  editedAt       DateTime?
  deletedForEveryone Boolean  @default(false)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([senderId])
  @@index([conversationId])
  @@index([createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  storyId   String
  chapterId String
  userId    String
  content   String
  likes     Int      @default(0)
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies   CommentReply[]
  commentLikes CommentLike[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storyId])
  @@index([chapterId])
  @@index([userId])
}

model CommentLike {
  id        String   @id @default(cuid())
  userId    String
  commentId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, commentId])
  @@index([commentId])
}

model CommentReply {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  content   String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([commentId])
  @@index([userId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model StoryLike {
  id        String   @id @default(cuid())
  userId    String
  storyId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, storyId])
  @@index([storyId])
}

model StoryRating {
  id        String   @id @default(cuid())
  userId    String
  storyId   String
  value     Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, storyId])
  @@index([storyId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  storyId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, storyId])
  @@index([storyId])
}

model ReadingProgress {
  id              String   @id @default(cuid())
  userId          String
  storyId         String
  chapterId       String
  progressPercent Float    @default(0)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  story           Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  chapter         Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  lastReadAt      DateTime @default(now())

  @@unique([userId, storyId, chapterId])
  @@index([userId])
}

// Listes de lecture personnelles (« En cours », « Terminés », « À lire plus
// tard ») : persistées côté serveur pour être IDENTIQUES sur tous les appareils
// (app native et PWA). storyId sans FK : une entrée orpheline est simplement
// ignorée côté client si le récit a disparu.
model ReadingListEntry {
  id        String   @id @default(cuid())
  userId    String
  storyId   String
  list      String   // 'currently' | 'completed' | 'later'
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, storyId, list])
  @@index([userId])
}

// Chapitre RÉELLEMENT lu (défilé jusqu'au bout) — distinct de ReadingHistory
// qui trace chaque OUVERTURE. C'est cette table qui alimente le pourcentage de
// progression, identique sur tous les appareils.
model ChapterRead {
  id        String   @id @default(cuid())
  userId    String
  storyId   String
  chapterId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, chapterId])
  @@index([userId])
}

// Citations sauvegardées pendant la lecture : persistées côté serveur (elles
// vivaient uniquement dans le localStorage, partagées entre comptes et perdues
// au changement d'appareil).
model SavedQuote {
  id         String   @id @default(cuid())
  userId     String
  storyId    String?
  chapterId  String?
  content    String
  storyTitle String?
  author     String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([userId])
}

model ReadingHistory {
  id        String   @id @default(cuid())
  userId    String
  storyId   String
  chapterId String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  chapter   Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([storyId])
}

model BlockedUser {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model Report {
  id         String   @id @default(cuid())
  reporterId String
  reportedId String
  reason     String?
  reporter   User     @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reported   User     @relation("ReportReported", fields: [reportedId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([reporterId, reportedId])
  @@index([reportedId])
}

model ReadingGroup {
  id          String         @id @default(cuid())
  name        String
  description String         @default("")
  avatar      String?
  storyId     String?
  creatorId   String
  creator     User           @relation("GroupCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  members     User[]         @relation("GroupMembers")
  memberships GroupMember[]
  messages    GroupMessage[]
  reads       GroupRead[]

  // Parametres (style WhatsApp). visibility: public | private | invite.
  visibility        String  @default("private")
  // Qui peut modifier les infos du groupe : all | admins.
  whoCanEditInfo    String  @default("admins")
  // Qui peut envoyer des messages : all | admins (mode annonce).
  messagePermission String  @default("all")
  allowReactions    Boolean @default(true)
  allowMedia        Boolean @default(true)
  // Approbation manuelle des demandes d'adhesion.
  requireApproval   Boolean @default(false)
  // Lien d'invitation.
  inviteCode        String? @unique
  inviteEnabled     Boolean @default(true)

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([creatorId])
}

// Adhesion d'un utilisateur a un groupe : ROLE + STATUT + date d'entree.
// Source de verite des roles/statuts (la relation members reste la presence
// "active" effective, pour ne pas casser le chat existant).
//   role   : owner | admin | moderator | member
//   status : active | pending | banned | removed
model GroupMember {
  id       String       @id @default(cuid())
  groupId  String
  userId   String
  role     String       @default("member")
  status   String       @default("active")
  joinedAt DateTime     @default(now())
  group    ReadingGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

model GroupMessageReaction {
  id        String       @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime     @default(now())
  message   GroupMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

// Suivi de LECTURE par membre d'un groupe (accuses de reception groupe) :
// horodatage du dernier message lu par chaque membre.
model GroupRead {
  id       String   @id @default(cuid())
  groupId  String
  userId   String
  lastRead DateTime @default(now())
  group    ReadingGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

model GroupMessage {
  id        String       @id @default(cuid())
  groupId   String
  senderId  String
  content   String
  // Réponse à un autre message + édition + suppression pour tout le monde.
  replyToId String?
  editedAt  DateTime?
  deletedForEveryone Boolean @default(false)
  // Moderation / mise en avant.
  pinned         Boolean   @default(false)
  pinnedAt       DateTime?
  isAnnouncement Boolean   @default(false)
  deletedByAdmin Boolean   @default(false)
  group     ReadingGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender    User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  reactions GroupMessageReaction[]
  createdAt DateTime     @default(now())

  @@index([groupId])
  @@index([createdAt])
}

model Otp {
  id        String   @id @default(cuid())
  email     String   @unique
  code      String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// Jetons d'appareils pour les notifications push (FCM). Un utilisateur peut
// avoir plusieurs appareils ; un même jeton est unique.
model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   @default("android")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
